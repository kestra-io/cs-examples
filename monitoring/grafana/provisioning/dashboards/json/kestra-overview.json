    {
      "id": 102,
      "title": "Host Metrics (node-exporter)",
      "type": "row",
      "collapsed": false,
      "panels": [],
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 96
      }
    },
    {
      "id": 24,
      "title": "Host CPU Utilization %",
      "description": "Total CPU busy time across all cores on the machine running the containers (via node-exporter). Dashed lines mark 80% (yellow) and 95% (red). This is the real ceiling behind every JVM and container above: sustained high host CPU will slow every process at once regardless of individual thread pool or heap headroom.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 97
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu utilization",
          "refId": "A"
        }
      ]
    },
    {
      "id": 25,
      "title": "Host Memory Utilization %",
      "description": "Host RAM in use as a percentage of total (via node-exporter, MemAvailable-based so page cache doesn't count as 'used'). Dashed lines mark 80% (yellow) and 95% (red). As of 2026-07-21, -Xmx and a deploy.resources.limits.memory cap are set explicitly on all 4 Kestra JVMs plus every sidecar (see Container Metrics section below), and the redundant kestra-worker-wg1 was disabled, bringing this down from ~94% to ~70-75% by design. If this climbs back toward 80%+, check the Container Memory Working Set panel for which service grew before adding capacity.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 97
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "memory utilization",
          "refId": "A"
        }
      ]
    },
    {
      "id": 26,
      "title": "Host Memory Used vs Total (Actual)",
      "description": "The real numbers behind Host Memory Utilization %: bytes used (solid) against total host RAM (dashed). Directly comparable to the JVM Heap Used vs Max panel above: sum the 'used' lines from that panel and compare against this total to see how much of the box's actual memory the JVMs plus everything else (Postgres, Traefik, Grafana, Prometheus) are consuming.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 105
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "overrides": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/total$/"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    10,
                    10
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "host memory used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "host memory total",
          "refId": "B"
        }
      ]
    },
    {
      "id": 27,
      "title": "Host Disk Consumed (%)",
      "description": "Disk space consumed on the filesystem backing Docker's storage (named volumes, container layers, images) via node-exporter, shown as a battery-style gauge. Thresholds at 80% (yellow) and 95% (red). A full disk here can crash containers outright: Postgres and Kestra's local storage both fail writes when out of space, and the Docker daemon itself can misbehave. This is one filesystem shared by all named volumes (kestra-data, postgres-data, grafana-data, prometheus-data), not broken out per-volume, since Docker's local volume driver doesn't give each volume its own quota.",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 113
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\", fstype=\"ext4\"} / node_filesystem_size_bytes{mountpoint=\"/\", fstype=\"ext4\"}))",
          "legendFormat": "disk consumed %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "title": "Container Metrics (cAdvisor)",
      "type": "row",
