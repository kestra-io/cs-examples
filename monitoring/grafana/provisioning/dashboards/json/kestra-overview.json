      "targets": [
        {
          "expr": "sum(container_spec_memory_limit_bytes{service!=\"\"}) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Host Memory: Sum of Containers vs Host Used vs Host Total",
      "description": "Reconciles the container-level view against the host-level view: sum of all container working sets, host memory actually used (from node-exporter), and host total. The gap between 'sum of containers' and 'host used' is page cache, the Docker daemon itself, and other non-container host processes, not something any per-service memory limit will touch.",
      "type": "timeseries",
