    {
      "id": 30,
      "title": "Current Memory Usage by Service (% of Host)",
      "description": "Snapshot ranking of each container's working set as a percentage of total host RAM, right now. Thresholds at 15% (yellow) and 30% (red) flag any single service that's disproportionately large relative to the whole box. Now that every service has a memory limit (set 2026-07-21), use this to catch a service creeping back up before it hits its cap, rather than to pick an initial candidate to limit.",
      "type": "bargauge",
      "datasource": {
